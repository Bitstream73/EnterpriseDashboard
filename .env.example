# ============================================================
# LCARS Dashboard — Environment Variables
# Copy this file to .env and fill in your values.
# NOTE: A pre-populated .env is included (gitignored) with
#       the Railway, OpenAI, and Pinecone keys already set.
# ============================================================

# === REQUIRED ===

# Railway Account Token
# The Captain's token is stored as RAILWAY_TOKEN in VabaBackgammon/.env
# It's pre-populated here as RAILWAY_API_TOKEN (the name this app expects).
# Create new tokens at: https://railway.com/account/tokens
RAILWAY_API_TOKEN=your_railway_account_token_here

# === OPTIONAL — enables dashboard sections when provided ===

# Anthropic Admin API Key
# IMPORTANT: This is NOT the same as the standard ANTHROPIC_API_KEY.
# Admin keys start with sk-ant-admin... and require an organization account.
# Individual accounts do NOT have access to the Usage Report API.
# Create at: https://console.anthropic.com/settings/admin-keys
# The standard key in VabaBackgammon/.env will NOT work here.
ANTHROPIC_ADMIN_API_KEY=sk-ant-admin...

# OpenAI API Key (pre-populated from VabaBackgammon/.env)
OPENAI_API_KEY=sk-...

# Pinecone (pre-populated from VabaBackgammon/.env — points to vababackgammon index)
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_HOST=https://your-index-host.svc.pinecone.io
PINECONE_INDEX_NAME=your-index-name

# === DASHBOARD CONFIG (optional, have defaults) ===

PORT=3000
DASHBOARD_TITLE=ENTERPRISE OPS CENTER

# Poll intervals in seconds
POLL_INTERVAL_RAILWAY_SECONDS=60
POLL_INTERVAL_AI_USAGE_SECONDS=300
POLL_INTERVAL_PINECONE_SECONDS=600
